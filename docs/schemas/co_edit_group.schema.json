{
  "$defs": {
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    }
  },
  "description": "协同编辑组。",
  "properties": {
    "group_id": {
      "description": "组 ID",
      "title": "Group Id",
      "type": "string"
    },
    "entities": {
      "description": "必须一起修改的实体",
      "items": {
        "type": "string"
      },
      "title": "Entities",
      "type": "array"
    },
    "reason": {
      "description": "原因",
      "title": "Reason",
      "type": "string"
    },
    "evidence_source": {
      "description": "证据来源",
      "items": {
        "$ref": "#/$defs/EvidenceSource"
      },
      "title": "Evidence Source",
      "type": "array"
    }
  },
  "required": [
    "group_id",
    "entities",
    "reason"
  ],
  "title": "CoEditGroup",
  "type": "object"
}