{
  "$defs": {
    "CoEditGroup": {
      "description": "协同编辑组。",
      "properties": {
        "group_id": {
          "description": "组 ID",
          "title": "Group Id",
          "type": "string"
        },
        "entities": {
          "description": "必须一起修改的实体",
          "items": {
            "type": "string"
          },
          "title": "Entities",
          "type": "array"
        },
        "reason": {
          "description": "原因",
          "title": "Reason",
          "type": "string"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        }
      },
      "required": [
        "group_id",
        "entities",
        "reason"
      ],
      "title": "CoEditGroup",
      "type": "object"
    },
    "DependencyEdge": {
      "description": "依赖边。",
      "properties": {
        "from_entity": {
          "description": "起点实体",
          "title": "From Entity",
          "type": "string"
        },
        "to_entity": {
          "description": "终点实体",
          "title": "To Entity",
          "type": "string"
        },
        "edge_type": {
          "description": "边类型 (caller-callee/import/wrapper/adapter/config-code-test)",
          "title": "Edge Type",
          "type": "string"
        },
        "strength": {
          "default": "strong",
          "description": "依赖强度 (strong/medium/weak)",
          "title": "Strength",
          "type": "string"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        }
      },
      "required": [
        "from_entity",
        "to_entity",
        "edge_type"
      ],
      "title": "DependencyEdge",
      "type": "object"
    },
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    },
    "SufficiencyStatus": {
      "description": "证据充分性状态。",
      "enum": [
        "sufficient",
        "insufficient",
        "partial",
        "unknown"
      ],
      "title": "SufficiencyStatus",
      "type": "string"
    }
  },
  "description": "结构证据卡。\n\n回答：哪些位置必须一起改，修改之间是什么依赖关系。",
  "properties": {
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "updated_by": {
      "title": "Updated By",
      "type": "string"
    },
    "dependency_edges": {
      "items": {
        "$ref": "#/$defs/DependencyEdge"
      },
      "title": "Dependency Edges",
      "type": "array"
    },
    "co_edit_groups": {
      "items": {
        "$ref": "#/$defs/CoEditGroup"
      },
      "title": "Co Edit Groups",
      "type": "array"
    },
    "propagation_risks": {
      "description": "传播风险描述",
      "items": {
        "type": "string"
      },
      "title": "Propagation Risks",
      "type": "array"
    },
    "sufficiency_status": {
      "$ref": "#/$defs/SufficiencyStatus",
      "default": "unknown"
    },
    "sufficiency_notes": {
      "default": "",
      "title": "Sufficiency Notes",
      "type": "string"
    }
  },
  "required": [
    "updated_by"
  ],
  "title": "StructuralCard",
  "type": "object"
}