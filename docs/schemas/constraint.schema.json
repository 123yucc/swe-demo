{
  "$defs": {
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    }
  },
  "description": "约束定义。",
  "properties": {
    "type": {
      "description": "约束类型 (requirement/interface/api/type/assertion/edge_case/compatibility)",
      "title": "Type",
      "type": "string"
    },
    "description": {
      "description": "约束描述",
      "title": "Description",
      "type": "string"
    },
    "source": {
      "description": "来源",
      "title": "Source",
      "type": "string"
    },
    "severity": {
      "default": "must",
      "description": "严重程度 (must/should/can)",
      "title": "Severity",
      "type": "string"
    },
    "evidence_source": {
      "description": "证据来源",
      "items": {
        "$ref": "#/$defs/EvidenceSource"
      },
      "title": "Evidence Source",
      "type": "array"
    }
  },
  "required": [
    "type",
    "description",
    "source"
  ],
  "title": "Constraint",
  "type": "object"
}