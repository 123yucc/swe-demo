{
  "$defs": {
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    }
  },
  "description": "代码实体引用。",
  "properties": {
    "name": {
      "description": "实体名称",
      "title": "Name",
      "type": "string"
    },
    "type": {
      "description": "实体类型 (function/class/module/route/config)",
      "title": "Type",
      "type": "string"
    },
    "file_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "所在文件路径",
      "title": "File Path"
    },
    "line_number": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "所在行号",
      "title": "Line Number"
    },
    "evidence_source": {
      "description": "证据来源",
      "items": {
        "$ref": "#/$defs/EvidenceSource"
      },
      "title": "Evidence Source",
      "type": "array"
    },
    "computed_confidence": {
      "default": 0.5,
      "description": "计算后的置信度 (0-1)",
      "title": "Computed Confidence",
      "type": "number"
    }
  },
  "required": [
    "name",
    "type"
  ],
  "title": "EntityReference",
  "type": "object"
}