{
  "$defs": {
    "CandidateLocation": {
      "description": "候选修复位置。",
      "properties": {
        "file_path": {
          "description": "文件路径",
          "title": "File Path",
          "type": "string"
        },
        "symbol_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "符号名称 (函数/类)",
          "title": "Symbol Name"
        },
        "symbol_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "符号类型",
          "title": "Symbol Type"
        },
        "region_start": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "起始行号",
          "title": "Region Start"
        },
        "region_end": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "结束行号",
          "title": "Region End"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        },
        "computed_confidence": {
          "default": 0.5,
          "description": "计算后的置信度 (0-1)，基于来源权重+匹配精确度+LLM评分",
          "title": "Computed Confidence",
          "type": "number"
        }
      },
      "required": [
        "file_path"
      ],
      "title": "CandidateLocation",
      "type": "object"
    },
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    },
    "SufficiencyStatus": {
      "description": "证据充分性状态。",
      "enum": [
        "sufficient",
        "insufficient",
        "partial",
        "unknown"
      ],
      "title": "SufficiencyStatus",
      "type": "string"
    }
  },
  "description": "定位证据卡。\n\n回答：应该改哪里。",
  "properties": {
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "updated_by": {
      "title": "Updated By",
      "type": "string"
    },
    "candidate_locations": {
      "items": {
        "$ref": "#/$defs/CandidateLocation"
      },
      "title": "Candidate Locations",
      "type": "array"
    },
    "test_to_code_mappings": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "测试到代码的映射",
      "title": "Test To Code Mappings",
      "type": "object"
    },
    "interface_to_code_mappings": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "接口到代码的映射 (route->文件/函数)",
      "title": "Interface To Code Mappings",
      "type": "object"
    },
    "sufficiency_status": {
      "$ref": "#/$defs/SufficiencyStatus",
      "default": "unknown"
    },
    "sufficiency_notes": {
      "default": "",
      "title": "Sufficiency Notes",
      "type": "string"
    }
  },
  "required": [
    "updated_by"
  ],
  "title": "LocalizationCard",
  "type": "object"
}