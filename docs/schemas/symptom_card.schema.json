{
  "$defs": {
    "EntityReference": {
      "description": "代码实体引用。",
      "properties": {
        "name": {
          "description": "实体名称",
          "title": "Name",
          "type": "string"
        },
        "type": {
          "description": "实体类型 (function/class/module/route/config)",
          "title": "Type",
          "type": "string"
        },
        "file_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "所在文件路径",
          "title": "File Path"
        },
        "line_number": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "所在行号",
          "title": "Line Number"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        },
        "computed_confidence": {
          "default": 0.5,
          "description": "计算后的置信度 (0-1)",
          "title": "Computed Confidence",
          "type": "number"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "EntityReference",
      "type": "object"
    },
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    },
    "ExpectedBehavior": {
      "description": "预期行为。",
      "properties": {
        "description": {
          "description": "修复后的预期行为",
          "title": "Description",
          "type": "string"
        },
        "grounded_in": {
          "description": "依据来源 (requirements/tests/docs)",
          "title": "Grounded In",
          "type": "string"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        }
      },
      "required": [
        "description",
        "grounded_in"
      ],
      "title": "ExpectedBehavior",
      "type": "object"
    },
    "ObservedFailure": {
      "description": "观察到的失败现象",
      "properties": {
        "description": {
          "description": "错误现象的详细描述",
          "title": "Description",
          "type": "string"
        },
        "trigger_condition": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "触发条件",
          "title": "Trigger Condition"
        },
        "exception_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "异常类型",
          "title": "Exception Type"
        },
        "stack_trace_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "堆栈跟踪摘要",
          "title": "Stack Trace Summary"
        },
        "error_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "错误信息",
          "title": "Error Message"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        }
      },
      "required": [
        "description"
      ],
      "title": "ObservedFailure",
      "type": "object"
    },
    "SufficiencyStatus": {
      "description": "证据充分性状态。",
      "enum": [
        "sufficient",
        "insufficient",
        "partial",
        "unknown"
      ],
      "title": "SufficiencyStatus",
      "type": "string"
    }
  },
  "description": "症状证据卡。\n\n回答：现在坏在哪里，修好以后应该表现成什么样。",
  "properties": {
    "version": {
      "default": 1,
      "description": "Card 版本号",
      "title": "Version",
      "type": "integer"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "updated_by": {
      "description": "更新的 agent 名称",
      "title": "Updated By",
      "type": "string"
    },
    "observed_failure": {
      "$ref": "#/$defs/ObservedFailure"
    },
    "expected_behavior": {
      "$ref": "#/$defs/ExpectedBehavior",
      "description": "预期行为"
    },
    "mentioned_entities": {
      "description": "提到的代码实体",
      "items": {
        "$ref": "#/$defs/EntityReference"
      },
      "title": "Mentioned Entities",
      "type": "array"
    },
    "hinted_scope": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "提示的作用域",
      "title": "Hinted Scope"
    },
    "sufficiency_status": {
      "$ref": "#/$defs/SufficiencyStatus",
      "default": "unknown"
    },
    "sufficiency_notes": {
      "default": "",
      "description": "充分性评估说明",
      "title": "Sufficiency Notes",
      "type": "string"
    },
    "evidence_sources": {
      "description": "使用的artifacts",
      "items": {
        "type": "string"
      },
      "title": "Evidence Sources",
      "type": "array"
    },
    "missing_artifacts": {
      "description": "缺失的artifacts",
      "items": {
        "type": "string"
      },
      "title": "Missing Artifacts",
      "type": "array"
    }
  },
  "required": [
    "updated_by",
    "observed_failure",
    "expected_behavior"
  ],
  "title": "SymptomCard",
  "type": "object"
}