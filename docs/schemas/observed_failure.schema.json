{
  "$defs": {
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    }
  },
  "description": "观察到的失败现象",
  "properties": {
    "description": {
      "description": "错误现象的详细描述",
      "title": "Description",
      "type": "string"
    },
    "trigger_condition": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "触发条件",
      "title": "Trigger Condition"
    },
    "exception_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "异常类型",
      "title": "Exception Type"
    },
    "stack_trace_summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "堆栈跟踪摘要",
      "title": "Stack Trace Summary"
    },
    "error_message": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "错误信息",
      "title": "Error Message"
    },
    "evidence_source": {
      "description": "证据来源",
      "items": {
        "$ref": "#/$defs/EvidenceSource"
      },
      "title": "Evidence Source",
      "type": "array"
    }
  },
  "required": [
    "description"
  ],
  "title": "ObservedFailure",
  "type": "object"
}