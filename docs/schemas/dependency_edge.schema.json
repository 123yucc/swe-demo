{
  "$defs": {
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    }
  },
  "description": "依赖边。",
  "properties": {
    "from_entity": {
      "description": "起点实体",
      "title": "From Entity",
      "type": "string"
    },
    "to_entity": {
      "description": "终点实体",
      "title": "To Entity",
      "type": "string"
    },
    "edge_type": {
      "description": "边类型 (caller-callee/import/wrapper/adapter/config-code-test)",
      "title": "Edge Type",
      "type": "string"
    },
    "strength": {
      "default": "strong",
      "description": "依赖强度 (strong/medium/weak)",
      "title": "Strength",
      "type": "string"
    },
    "evidence_source": {
      "description": "证据来源",
      "items": {
        "$ref": "#/$defs/EvidenceSource"
      },
      "title": "Evidence Source",
      "type": "array"
    }
  },
  "required": [
    "from_entity",
    "to_entity",
    "edge_type"
  ],
  "title": "DependencyEdge",
  "type": "object"
}