{
  "$defs": {
    "Constraint": {
      "description": "约束定义。",
      "properties": {
        "type": {
          "description": "约束类型 (requirement/interface/api/type/assertion/edge_case/compatibility)",
          "title": "Type",
          "type": "string"
        },
        "description": {
          "description": "约束描述",
          "title": "Description",
          "type": "string"
        },
        "source": {
          "description": "来源",
          "title": "Source",
          "type": "string"
        },
        "severity": {
          "default": "must",
          "description": "严重程度 (must/should/can)",
          "title": "Severity",
          "type": "string"
        },
        "evidence_source": {
          "description": "证据来源",
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          },
          "title": "Evidence Source",
          "type": "array"
        }
      },
      "required": [
        "type",
        "description",
        "source"
      ],
      "title": "Constraint",
      "type": "object"
    },
    "EvidenceSource": {
      "description": "证据来源溯源。\n\n记录证据的来源、匹配细节和置信度计算依据。",
      "properties": {
        "source_type": {
          "description": "来源类型 (artifact/repo/test/ast/llm)",
          "title": "Source Type",
          "type": "string"
        },
        "source_path": {
          "description": "来源文件路径",
          "title": "Source Path",
          "type": "string"
        },
        "matching_detail": {
          "additionalProperties": true,
          "description": "匹配细节",
          "title": "Matching Detail",
          "type": "object"
        },
        "confidence_contribution": {
          "default": 1.0,
          "description": "置信度贡献 (0-1)",
          "title": "Confidence Contribution",
          "type": "number"
        }
      },
      "required": [
        "source_type",
        "source_path"
      ],
      "title": "EvidenceSource",
      "type": "object"
    },
    "SufficiencyStatus": {
      "description": "证据充分性状态。",
      "enum": [
        "sufficient",
        "insufficient",
        "partial",
        "unknown"
      ],
      "title": "SufficiencyStatus",
      "type": "string"
    }
  },
  "description": "约束证据卡。\n\n回答：什么修改才算正确，什么不能改坏。",
  "properties": {
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "updated_by": {
      "title": "Updated By",
      "type": "string"
    },
    "must_do": {
      "description": "必须做的约束",
      "items": {
        "type": "string"
      },
      "title": "Must Do",
      "type": "array"
    },
    "must_not_break": {
      "description": "不能破坏的约束",
      "items": {
        "type": "string"
      },
      "title": "Must Not Break",
      "type": "array"
    },
    "allowed_behavior": {
      "description": "允许的行为",
      "items": {
        "type": "string"
      },
      "title": "Allowed Behavior",
      "type": "array"
    },
    "forbidden_behavior": {
      "description": "禁止的行为",
      "items": {
        "type": "string"
      },
      "title": "Forbidden Behavior",
      "type": "array"
    },
    "compatibility_expectations": {
      "description": "兼容性期望",
      "items": {
        "type": "string"
      },
      "title": "Compatibility Expectations",
      "type": "array"
    },
    "edge_case_obligations": {
      "description": "边界情况义务",
      "items": {
        "type": "string"
      },
      "title": "Edge Case Obligations",
      "type": "array"
    },
    "constraints": {
      "items": {
        "$ref": "#/$defs/Constraint"
      },
      "title": "Constraints",
      "type": "array"
    },
    "api_signatures": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "API 签名约束",
      "title": "Api Signatures",
      "type": "object"
    },
    "type_constraints": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "类型约束",
      "title": "Type Constraints",
      "type": "object"
    },
    "backward_compatibility": {
      "default": true,
      "description": "是否需要向后兼容",
      "title": "Backward Compatibility",
      "type": "boolean"
    },
    "compatibility_notes": {
      "default": "",
      "description": "兼容性说明",
      "title": "Compatibility Notes",
      "type": "string"
    },
    "sufficiency_status": {
      "$ref": "#/$defs/SufficiencyStatus",
      "default": "unknown"
    },
    "sufficiency_notes": {
      "default": "",
      "title": "Sufficiency Notes",
      "type": "string"
    }
  },
  "required": [
    "updated_by"
  ],
  "title": "ConstraintCard",
  "type": "object"
}